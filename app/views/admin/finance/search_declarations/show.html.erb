<% page_data(title: "Search declarations") %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">

    <%= render Shared::TopSearchComponent.new(
      query_param: :declaration_api_id,
      label_text: "Search for a declaration",
      hint_text: "Enter a declaration ID",
      submit_text: "Search",
      url: admin_search_declarations_path
    ) %>

    <% if @no_results_found %>
      <p class="govuk-body govuk-!-margin-top-4">
        No results found
      </p>
    <% end %>
  </div>
</div>
