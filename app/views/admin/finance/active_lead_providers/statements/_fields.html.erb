<%= content_for(:error_summary) { form.govuk_error_summary } %>

<%= form.govuk_collection_select :contract_id,
    active_lead_provider.contracts,
    :id,
    :description,
    label: { text: "Contract", size: "m" },
    options: { include_blank: "Choose a contract" } %>

<%= form.govuk_collection_select :month,
    (1..12).map { |month_number| [month_number, Date::MONTHNAMES[month_number]] },
    :first,
    :last,
    label: { text: "Month", size: "m" },
    options: { include_blank: "Choose a month" } %>

<%= form.govuk_collection_select :year,
    (contract_period.year..(contract_period.year + 4)).to_a,
    :to_s,
    :to_s,
    label: { text: "Year", size: "m" },
    options: { include_blank: "Choose a year" } %>

<%= form.govuk_date_field :deadline_date,
    legend: { text: "Deadline date", size: "m" } %>

<%= form.govuk_date_field :payment_date,
    legend: { text: "Payment date", size: "m" } %>
