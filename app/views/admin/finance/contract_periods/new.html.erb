<%
  page_data(
    title: "Add Contract period",
    error: @contract_period.errors.present?,
    backlink_href: admin_contract_periods_path
  )
%>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <%= form_with model: [:admin, @contract_period], local: true do |f| %>
      <%= render "fields", form: f %>
      <%= f.govuk_submit "Save" %>
    <% end %>

    <p class="govuk-body">
      <%= govuk_link_to "Cancel and return to Contract periods", admin_contract_periods_path %>
    </p>
  </div>
</div>
