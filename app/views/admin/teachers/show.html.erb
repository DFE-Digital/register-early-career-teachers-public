<%
  page_data(
    title: teacher_full_name(@teacher),
    caption: teacher_trn(@teacher),
    caption_size: 'm',
    error: false,
    backlink_href: admin_teachers_path(page: @page)
  )
%>

<%= render(Teachers::InductionSummaryComponent.new(teacher: @teacher, is_admin: true)) %>
<%= render(Teachers::CurrentInductionPeriodComponent.new(teacher: @teacher, enable_edit: true)) %>
<%= render(Teachers::PastInductionPeriodsComponent.new(teacher: @teacher, enable_edit: true)) %>

<h2 class='govuk-heading-m'>Timeline</h2>
<% if @events.any? %>
  <%= render(TimelineComponent.new(@events)) %>
<% else %>
  <p class='govuk-body'>No timeline of events for this teacher.</p>
<% end %>

<%= govuk_warning_text(text: "Some of this teacher's records could not be migrated") if @teacher.has_migration_failures? %>
