<% page_data(title: "Teachers") %>

<%= form_with method: :get, data: { turbo: false }, html: { class: "app-teachers-filters" } do |f| %>
  <%= f.govuk_text_field(
        :q,
        value: params[:q],
        label: { text: "Search for teacher", size: "s" },
        hint: { text: "Name, TRN or API participant ID" },
        form_group: { class: "app-teachers-filters__search" }
      ) %>

  <%= f.govuk_collection_select(
        :role,
        teacher_role_filter_options,
        :value,
        :name,
        label: { text: "Role", size: "s" },
        options: { selected: params[:role], include_blank: "All" }
      ) %>

  <%= f.govuk_collection_select(
        :contract_period,
        teacher_contract_period_filter_options,
        :value,
        :name,
        label: { text: "Contract period", size: "s" },
        options: { selected: params[:contract_period], include_blank: "All" }
      ) %>

  <%= f.govuk_submit "Search", secondary: true %>
<% end %>

<%= govuk_table do |table| %>
  <% table.with_head do |head| %>
    <% head.with_row do |row| %>
      <% row.with_cell(text: "Name") %>
      <% row.with_cell(text: "TRN") %>
      <% row.with_cell(text: "Role") %>
      <% row.with_cell(text: "Contract period") %>
    <% end %>
  <% end %>

  <% table.with_body do |body| %>
    <% @teachers.each do |teacher| %>
      <% body.with_row do |row| %>
        <% row.with_cell do %>
          <%= govuk_link_to(
                teacher_full_name(teacher),
                admin_teacher_path(teacher, page: params[:page], q: params[:q])
              ) %>
        <% end %>
        <% row.with_cell(text: teacher.trn) %>
        <% row.with_cell(text: "TODO") %>
        <% row.with_cell(text: "TODO") %>
      <% end %>
    <% end %>
  <% end %>
<% end %>


<%= govuk_button_link_to("Import a record from TRS", new_admin_import_ect_find_path, secondary: true) %>

<%= render Shared::PaginationSummaryComponent.new(pagy: @pagy, record_name: "results") %>

