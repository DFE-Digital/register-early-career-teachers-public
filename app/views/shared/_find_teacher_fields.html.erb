<%=
  f.govuk_text_field(
    :trn,
    width: 10,
    label: { text: "Teacher reference number (TRN)", size: "m" },
    hint: {
      text: "
        This unique ID is usually 7 digits long, for example 4567814. It may
        also include letters or a slash, for example RP99/12345. It can be found
        on their payslip, teaching contract or registration document from the
        GTCE.
      ".squish,
      size: "s"
    },
    extra_letter_spacing: true
  )
%>

<%=
  f.govuk_date_field(
    :date_of_birth,
    width: "two-thirds",
    legend: { text: "Date of birth", size: "m", tag: "h3" },
    hint: { text: "For example, 31 3 1980" }
  )
%>
