<%= yield(:error_summary) %>

<%= render partial: "layouts/shared/notification_banners" %>

<% if flash[:notice] %>
  <%= govuk_notification_banner(title_text: "Important", text: flash[:notice]) %>
<% end %>

<% if flash[:alert] %>
  <%= govuk_notification_banner(title_text: "Success", success: true) do |banner| %>
    <% banner.with_heading(text: flash_alert_heading, classes: 'govuk-notification-banner__heading') %>
    <% if flash_alert_body %>
      <p class="govuk-body"><%= flash_alert_body %></p>
    <% end %>
  <% end %>
<% end %>

<% if flash[:error] %>
  <div class="govuk-error-summary" data-module="govuk-error-summary">
    <div role="alert">
      <h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body">
        <p class="govuk-body"><%= flash[:error] %></p>
      </div>
    </div>
  </div>
<% end %>
