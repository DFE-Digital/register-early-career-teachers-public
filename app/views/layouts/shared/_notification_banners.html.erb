<% if Rails.application.config.enable_incident_banner %>
  <%= govuk_notification_banner(title_text: "There are intermittent issues accessing the service") do %>
    You might be experiencing issues signing in. We are working on resolving the
    issue. You should be able to sign in if you access the service directly
    through <%= govuk_link_to("https://www.register-early-career-teachers.education.gov.uk/", "https://www.register-early-career-teachers.education.gov.uk/") %>
  <% end %>
<% end %>

<% if Rails.application.config.enable_maintenance_banner %>
  <%= govuk_notification_banner(title_text: "Important") do %>
    This service will be unavailable from midday on 27 April until 9am on 28 April.
  <% end %>
<% end %>

<% if Schools::RegistrationWindow.closed? %>
  <%= govuk_notification_banner(title_text: "Important") do %>
    <h3 class="govuk-notification-banner__heading">Registration not currently open</h3>
    <p class="govuk-body">You cannot register ECTs or mentors for the 2025 or 2026 academic years until we open registration on 15 June.</p>
  <% end %>
<% end %>
