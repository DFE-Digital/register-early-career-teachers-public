<% page_data(title: "Check your answers before submitting", backlink_href: @wizard.previous_step_path) %>

<h2 class="govuk-heading-m">Teacher details</h2>
<%= govuk_summary_list do |summary_list|
  summary_list.with_row do |row|
    row.with_key(text: 'Name')
    row.with_value(text: @ect.full_name)
    row.with_action(text: "Change", visually_hidden_text: "name", href: schools_register_ect_wizard_review_ect_details_path)
  end

  summary_list.with_row do |row|
    row.with_key(text: 'Teacher Reference Number (TRN)')
    row.with_value(text: @ect.trn)
    row.with_action(text: "Change", visually_hidden_text: "teacher reference number", href: schools_register_ect_wizard_find_ect_path)
  end

  summary_list.with_row do |row|
    row.with_key(text: 'Date of birth')
    row.with_value(text: @ect.govuk_date_of_birth)
    row.with_action(text: "Change", visually_hidden_text: "date of birth", href: schools_register_ect_wizard_find_ect_path)
  end

  summary_list.with_row do |row|
    row.with_key(text: 'Email address')
    row.with_value(text: @ect.email)
    row.with_action(text: "Change", visually_hidden_text: "email address", href: schools_register_ect_wizard_email_address_path)
  end

  summary_list.with_row do |row|
    row.with_key(text: 'School start date')
    row.with_value(text: @ect.start_date)
    row.with_action(text: "Change", visually_hidden_text: "School start date", href: schools_register_ect_wizard_start_date_path)
  end

  summary_list.with_row do |row|
    row.with_key(text: 'Working pattern')
    row.with_value(text: @ect.formatted_working_pattern)
    row.with_action(text: "Change", visually_hidden_text: "Working pattern", href: schools_register_ect_wizard_working_pattern_path)
  end

  summary_list.with_row do |row|
    row.with_key(text: 'Appropriate body')
    row.with_value(text: @ect.formatted_appropriate_body_name)
    row.with_action(text: "Change", visually_hidden_text: "Appropriate body", href: schools_register_ect_wizard_state_school_appropriate_body_path)
  end

  summary_list.with_row do |row|
    row.with_key(text: 'Programme type')
    row.with_value(text: @ect.formatted_programme_type)
    row.with_action(text: "Change", visually_hidden_text: "programme type", href: schools_register_ect_wizard_programme_type_path)
  end
end %>

<%= form_with(model: @wizard.current_step, url: @wizard.current_step_path) do |f| %>
  <%= content_for(:error_summary) { f.govuk_error_summary } %>

  <%= f.govuk_submit "Confirm details" %>
<% end %>
