<%= form.govuk_radio_buttons_fieldset :appropriate_body_type, legend: { text: "What type of appropriate body will be supporting #{@wizard.teacher_full_name}'s induction", hidden: true } do %>
  <%= form.govuk_radio_button :appropriate_body_type,
                            :national,
                            label: { text: AppropriateBody::ISTIP }, link_errors: true %>

  <%= form.govuk_radio_button :appropriate_body_type,
    :teaching_school_hub,
    label: { text: "A different appropriate body (teaching school hub)" } do %>

    <%= form.govuk_collection_select(:appropriate_body_id,
                                  @wizard.current_step.appropriate_bodies_except_current,
                                  :id,
                                  :name,
                                  label: { text: "Enter appropriate body name" },
                                  options: { include_blank: true },
                                  class: "autocomplete"
                                ) 
    %>
  <% end %>
<% end %>
