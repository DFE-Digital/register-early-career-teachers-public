<% page_data(
    title: "Working pattern updated for #{@wizard.teacher_full_name}",
    header: false
) %>

<%= govuk_panel(
      title_text: <<~TXT.squish
        You have changed #{@wizard.teacher_full_name}’s working pattern to
        #{@wizard.current_step.new_working_pattern.humanize.downcase}
      TXT
    ) %>

<p class="govuk-body">
  <%= govuk_link_to(
        "Back to #{@wizard.teacher_full_name}’s details",
        schools_ect_path(@wizard.ect_at_school_period),
        no_visited_state: true
      ) %>
</p>
