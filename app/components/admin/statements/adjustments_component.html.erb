<div class="finance-panel govuk-!-margin-top-5 govuk-!-margin-bottom-5">
  <%= govuk_table do |table| 
    table.with_caption(text: "Additional adjustments", size: "m") 

    table.with_head do |head|
      head.with_row do |row|
        row.with_cell(header: true) { "Payment type" }
        row.with_cell(header: true) { "" }
        row.with_cell(header: true, numeric: true) { "Payments" }
      end
    end

    table.with_body do |body|
      if adjustments.any?
        adjustments.each do |adjustment|
          body.with_row do |row|
            row.with_cell { adjustment.payment_type }
            row.with_cell { change_or_remove_links(adjustment) }
            row.with_cell(numeric: true) { number_to_pounds(adjustment.amount) }
          end
        end
      end
    end
  end %>

  <% if adjustment_editable? %>
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half">
          <p>
            <%= govuk_link_to("Add", new_admin_finance_statement_adjustment_path(statement), visually_hidden_suffix: "adjustment") %>
          </p>
      </div>
        
      <div class="govuk-!-text-align-right govuk-heading-s govuk-grid-column-one-half">
        Total
        <br />
        <%= number_to_pounds(total_amount) %>
      </div>
    </div>
  <% else %>
    <div class="govuk-!-text-align-right govuk-heading-s govuk-!-margin-bottom-0">
      Total
    </div>
    <div class="govuk-!-text-align-right govuk-heading-s">
      <%= number_to_pounds(total_amount) %>
    </div>
  <% end %>
</div>
