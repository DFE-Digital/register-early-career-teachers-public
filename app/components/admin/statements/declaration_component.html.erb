<div class="finance-panel">
  <%=
    govuk_table do |table|
      table.with_caption(text: "Declarations", size: "m")
      table.with_head do |head|
        head.with_row do |row|
          row.with_cell(header: false) 
          row.with_cell(header: true) { "Totals" }
        end
      end

      table.with_body do |body|
        declaration_type_outputs.each do |declaration_type_output|
          body.with_row do |row|
            row.with_cell { declaration_type_output.declaration_type.humanize }
            row.with_cell(numeric: true) { declaration_type_output.billable_count - declaration_type_output.refundable_count }
          end
        end
      end
    end
  %>
</div>
