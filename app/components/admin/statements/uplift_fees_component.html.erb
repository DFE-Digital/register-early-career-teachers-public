<div class="finance-panel govuk-!-margin-top-5 govuk-!-margin-bottom-5">
  <%= govuk_table do |table|
    table.with_caption(text: "Uplift fees", size: "m")
    table.with_head do |head|
      head.with_row do |row|
        row.with_cell(text: "Number of participants", header: true)
        row.with_cell(text: "Fee per participant", header: true, numeric: true)
        row.with_cell(text: "Payments", header: true, numeric: true)
      end
    end
    table.with_body do |body|
      body.with_row do |row|
        row.with_cell(text: net_count)
        row.with_cell(text: number_to_pounds(uplift_fee_per_declaration), numeric: true)
        row.with_cell(text: number_to_pounds(total_net_amount), numeric: true)
      end
    end
  end %>
  <div class="govuk-!-text-align-right govuk-heading-s govuk-!-margin-bottom-0">
    Total
  </div>
  <div class="govuk-!-text-align-right govuk-heading-s">
    <%= number_to_pounds(total_net_amount) %>
  </div>
</div>
