<% calculators.each do |calculator| %>
  <div class="finance-panel govuk-!-margin-top-5 govuk-!-margin-bottom-5">
    <%=
      govuk_table do |table|
        table.with_caption(text: calculator.caption_text, size: "m")

        table.with_head do |head|
          head.with_row do |row|
            row.with_cell(header: true) { "Outputs" }
            calculator.columns.each do |header|
              row.with_cell(header: true, numeric: true) { header }
            end
            row.with_cell(header: true, numeric: true) { "Payments" }
          end
        end

        table.with_body do |body|
          outputs_by_type(calculator).each do |type, outputs|

            body.with_row do |row|
              row.with_cell(header: true) { type.underscore.humanize }

              declaration_counts(outputs).each do |value|
                row.with_cell(numeric: true) { value.to_s }
              end

              row.with_cell(numeric: true) { "" }
            end

            body.with_row do |row|
              row.with_cell { calculator.fee_label }

              declaration_fees(outputs).each do |value|
                row.with_cell(numeric: true) { number_to_pounds(value) }
              end

              row.with_cell(numeric: true) do
                number_to_pounds(declaration_total(outputs))
              end
            end
          end
        end
      end
    %>

    <div class="govuk-!-text-align-right govuk-heading-s govuk-!-margin-bottom-0">
      <%= calculator.total_label %>
    </div>
    <div class="govuk-!-text-align-right govuk-heading-s">
      <%= number_to_pounds(calculator.outputs.total_billable_amount) %>
    </div>
  </div>
<% end %>
