<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h2 class="govuk-heading-s">
      Manage ECTs
    </h2>    
    <p>
      <%= link_to new_ab_claim_an_ect_find_path, class: "govuk-button govuk-!-margin-bottom-2" do %>
        Find and claim a new ECT
      <% end %>
    </p>
    
    <h2 class="govuk-heading-s">
      Upload a CSV
    </h2>
    <p>
      <%= govuk_link_to("Record outcomes for multiple ECTs", batch_action_path, no_visited_state: true) %>
    </p>
    <p>
      <%= govuk_link_to("Claim multiple new ECTs", batch_claim_path, no_visited_state: true) %>
    </p>
    <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
  </div>
</div>
